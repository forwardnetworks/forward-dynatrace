{
  "schemaVersion": "forward-dynatrace-connector/v1",
  "packageUrl": "https://package.example.com/dynatrace-forward/latest/",
  "signatureUrl": "https://package.example.com/dynatrace-forward/latest/forward-dynatrace-package.sig",
  "publicKey": "/secure/path/forward-dynatrace-public.pem",
  "requireSignature": true,
  "forwardBaseUrl": "https://forward.example.com",
  "forwardNetworkId": "<network-id>",
  "batchSize": 500,
  "maxRetries": 3,
  "maxPackageAgeMinutes": 1440,
  "failOnDrift": true,
  "apply": false,
  "reportPath": "forward-import-report.json",
  "metricsPath": "forward-import-metrics.prom",
  "statusArtifactPath": "forward-ingest-status.json"
}
