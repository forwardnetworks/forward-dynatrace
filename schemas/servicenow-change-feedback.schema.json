{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/forwardnetworks/forward-dynatrace/schemas/servicenow-change-feedback.schema.json",
  "title": "ServiceNow change-assurance feedback receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "mode", "change", "decision", "reasonCodes", "idempotencyKey", "evidence", "publication"],
  "properties": {
    "schemaVersion": { "const": "forward-dynatrace-servicenow-change-feedback/v1" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "mode": { "enum": ["dry-run", "apply"] },
    "change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "sysId"],
      "properties": {
        "number": { "type": "string", "pattern": "^CHG[0-9]+$" },
        "sysId": { "type": "string", "pattern": "^[0-9a-f]{32}$" }
      }
    },
    "decision": { "enum": ["pass", "warn", "fail"] },
    "reasonCodes": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" } },
    "idempotencyKey": { "type": "string", "pattern": "^forward-dynatrace:[a-f0-9]{64}$" },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "attachmentFileName", "contentType", "bytes"],
      "properties": {
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "attachmentFileName": { "type": "string", "pattern": "^fwd-dt-assurance-[a-f0-9]{64}\\.json$", "maxLength": 100 },
        "contentType": { "const": "application/json" },
        "bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workNote", "attachment"],
      "properties": {
        "workNote": { "$ref": "#/definitions/publicationItem" },
        "attachment": { "$ref": "#/definitions/publicationItem" }
      }
    }
  },
  "definitions": {
    "publicationItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "sysId"],
      "properties": {
        "status": { "enum": ["planned", "created", "existing"] },
        "sysId": { "type": ["string", "null"] }
      }
    }
  }
}
