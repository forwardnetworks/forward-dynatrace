{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/forwardnetworks/forward-dynatrace/schemas/forward-intent-checks.schema.json",
  "title": "Forward for Dynatrace generated intent checks",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": true,
    "required": ["definition", "enabled", "name", "tags"],
    "properties": {
      "definition": {
        "type": "object",
        "additionalProperties": true,
        "required": ["checkType", "filters"],
        "properties": {
          "checkType": { "const": "Existential" },
          "filters": { "type": "object" }
        }
      },
      "enabled": { "type": "boolean" },
      "name": { "type": "string", "minLength": 1 },
      "note": { "type": "string" },
      "priority": { "type": "string" },
      "tags": {
        "type": "array",
        "minItems": 4,
        "uniqueItems": true,
        "items": { "type": "string", "minLength": 1 },
        "allOf": [
          { "contains": { "const": "managed-by:com.forward.dynatrace" } },
          { "contains": { "const": "contract-version:1" } },
          { "contains": { "type": "string", "pattern": "^source-instance:[a-z0-9][a-z0-9._:-]{2,127}$" } },
          { "contains": { "type": "string", "pattern": "^source-key:sha256:[a-f0-9]{64}$" } }
        ]
      }
    }
  }
}
