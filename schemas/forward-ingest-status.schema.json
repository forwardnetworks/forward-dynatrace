{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/forwardnetworks/forward-dynatrace/schemas/forward-ingest-status.schema.json",
  "title": "Forward for Dynatrace ingest status",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "runId",
    "packageId",
    "mode",
    "forwardAccessProfile",
    "importState",
    "packageSignature",
    "target",
    "counts",
    "plannedChecks"
  ],
  "properties": {
    "schemaVersion": { "const": "forward-dynatrace-status/v1" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "runId": { "$ref": "#/definitions/nullableString" },
    "packageId": { "$ref": "#/definitions/nullableString" },
    "mode": { "$ref": "#/definitions/nullableString" },
    "forwardAccessProfile": {
      "enum": ["read-only", "network-operator", "network-admin", null]
    },
    "importState": { "enum": ["valid", "staged", "reconciled", "needs-review", "applied", "failed", null] },
    "applyPolicy": { "$ref": "#/definitions/nullableString" },
    "packageIntegrity": { "type": ["object", "null"], "additionalProperties": true },
    "packageSignature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": { "status": { "type": "string", "minLength": 1 } }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["networkId", "snapshotId"],
      "properties": {
        "networkId": { "$ref": "#/definitions/nullableString" },
        "snapshotId": { "$ref": "#/definitions/nullableString" }
      }
    },
    "counts": { "$ref": "#/definitions/reconciliationCounts" },
    "unresolvedCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changed", "stale"],
      "properties": {
        "changed": { "$ref": "#/definitions/nonNegativeInteger" },
        "stale": { "$ref": "#/definitions/nonNegativeInteger" }
      }
    },
    "mutationCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created", "updated", "deactivated"],
      "properties": {
        "created": { "$ref": "#/definitions/nonNegativeInteger" },
        "updated": { "$ref": "#/definitions/nonNegativeInteger" },
        "deactivated": { "$ref": "#/definitions/nonNegativeInteger" }
      }
    },
    "mutationFailure": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["phase", "statusCode", "affectedCount", "recoveryRequired"],
      "properties": {
        "phase": { "type": "string", "minLength": 1 },
        "statusCode": { "type": ["integer", "null"], "minimum": 100, "maximum": 599 },
        "affectedCount": { "$ref": "#/definitions/nonNegativeInteger" },
        "recoveryRequired": { "const": true }
      }
    },
    "postApplyVerification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "planned", "counts"],
      "properties": {
        "state": { "enum": ["not-run", "pending", "verified", "failed", "unavailable"] },
        "planned": { "$ref": "#/definitions/nonNegativeInteger" },
        "counts": {
          "anyOf": [
            { "$ref": "#/definitions/reconciliationCounts" },
            { "type": "null" }
          ]
        }
      }
    },
    "approval": { "type": ["object", "null"], "additionalProperties": true },
    "importPlan": { "type": ["object", "null"], "additionalProperties": true },
    "plannedChecks": { "$ref": "#/definitions/nonNegativeInteger" },
    "plannedNqeChecks": { "$ref": "#/definitions/nonNegativeInteger" },
    "plannedNqeDiffRequests": { "$ref": "#/definitions/nonNegativeInteger" },
    "durationMs": { "$ref": "#/definitions/nonNegativeInteger" }
  },
  "definitions": {
    "nullableString": { "type": ["string", "null"] },
    "nonNegativeInteger": { "type": "integer", "minimum": 0 },
    "reconciliationCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create", "unchanged", "changed", "stale", "collision"],
      "properties": {
        "create": { "$ref": "#/definitions/nonNegativeInteger" },
        "unchanged": { "$ref": "#/definitions/nonNegativeInteger" },
        "changed": { "$ref": "#/definitions/nonNegativeInteger" },
        "stale": { "$ref": "#/definitions/nonNegativeInteger" },
        "collision": { "$ref": "#/definitions/nonNegativeInteger" }
      }
    }
  }
}
