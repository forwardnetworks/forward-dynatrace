{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/forwardnetworks/forward-dynatrace/schemas/servicenow-scope-mapping.schema.json",
  "title": "ServiceNow to Dynatrace and Forward scope mapping",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "mappingId",
    "environment",
    "owner",
    "observedAt",
    "expiresAt",
    "minimumConfidence",
    "mappings"
  ],
  "properties": {
    "schemaVersion": { "const": "forward-dynatrace-servicenow-scope-mapping/v1" },
    "mappingId": { "$ref": "#/definitions/identifier" },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environmentId",
        "serviceNowInstanceAlias",
        "dynatraceEnvironmentAlias",
        "forwardNetworkId"
      ],
      "properties": {
        "environmentId": { "$ref": "#/definitions/identifier" },
        "serviceNowInstanceAlias": { "$ref": "#/definitions/identifier" },
        "dynatraceEnvironmentAlias": { "$ref": "#/definitions/identifier" },
        "forwardNetworkId": { "type": "string", "minLength": 1, "maxLength": 255 }
      }
    },
    "owner": { "$ref": "#/definitions/owner" },
    "observedAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "minimumConfidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": { "$ref": "#/definitions/mappingEntry" }
    }
  },
  "definitions": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["team", "contact"],
      "properties": {
        "team": { "type": "string", "minLength": 1, "maxLength": 128 },
        "contact": { "type": "string", "minLength": 1, "maxLength": 255 }
      }
    },
    "sourceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["table", "sysId"],
      "properties": {
        "table": { "type": "string", "pattern": "^[a-z][a-z0-9_]{0,79}$" },
        "sysId": { "type": "string", "pattern": "^[0-9a-f]{32}$" }
      }
    },
    "forwardEndpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["serviceEntityId", "locationType", "value"],
      "properties": {
        "serviceEntityId": { "type": "string", "minLength": 1, "maxLength": 255 },
        "locationType": {
          "enum": ["HostFilter", "SubnetLocationFilter", "DeviceFilter"]
        },
        "value": { "type": "string", "minLength": 1, "maxLength": 255 }
      }
    },
    "mappingEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mappingEntryId",
        "sourceRecord",
        "serviceEntityIds",
        "forwardEndpoints",
        "confidence",
        "status",
        "observedAt",
        "expiresAt"
      ],
      "properties": {
        "mappingEntryId": { "$ref": "#/definitions/identifier" },
        "sourceRecord": { "$ref": "#/definitions/sourceRecord" },
        "serviceEntityIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 255 }
        },
        "forwardEndpoints": {
          "type": "array",
          "minItems": 1,
          "maxItems": 500,
          "items": { "$ref": "#/definitions/forwardEndpoint" }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "status": { "enum": ["reviewed", "disabled"] },
        "observedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
