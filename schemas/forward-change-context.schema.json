{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/forwardnetworks/forward-dynatrace/schemas/forward-change-context.schema.json",
  "title": "Forward for Dynatrace change context",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "changeId", "deploymentId", "observedAt", "serviceEntityIds", "dynatrace"],
  "properties": {
    "schemaVersion": { "const": "forward-dynatrace-change-context/v1" },
    "changeId": { "type": "string", "minLength": 1, "maxLength": 32 },
    "deploymentId": { "type": "string", "minLength": 1, "maxLength": 255 },
    "observedAt": { "type": "string", "format": "date-time" },
    "serviceEntityIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 255 }
    },
    "dynatrace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deploymentState", "serviceHealth", "openProblemCount"],
      "properties": {
        "deploymentState": { "enum": ["SUCCEEDED", "FAILED", "IN_PROGRESS", "UNKNOWN"] },
        "serviceHealth": { "enum": ["HEALTHY", "DEGRADED", "UNHEALTHY", "UNKNOWN"] },
        "openProblemCount": { "type": "integer", "minimum": 0, "maximum": 2147483647 }
      }
    }
  }
}
