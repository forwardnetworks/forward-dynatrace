{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/forwardnetworks/forward-dynatrace/schemas/servicenow-change-preflight.schema.json",
  "title": "ServiceNow change-assurance preflight",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "observedAt",
    "mode",
    "source",
    "change",
    "scope",
    "authorization",
    "nextStages"
  ],
  "properties": {
    "schemaVersion": { "const": "forward-dynatrace-servicenow-change-preflight/v1" },
    "observedAt": { "type": "string", "format": "date-time" },
    "mode": { "const": "read-only" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instanceAlias", "table", "authoritativeRead"],
      "properties": {
        "instanceAlias": { "type": "string", "minLength": 1, "maxLength": 128 },
        "table": { "const": "change_request" },
        "authoritativeRead": { "const": true }
      }
    },
    "change": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "number",
        "sysId",
        "deploymentId",
        "approval",
        "state",
        "risk",
        "assignmentGroup",
        "window"
      ],
      "properties": {
        "number": { "type": "string", "maxLength": 32, "pattern": "^CHG[0-9]+$" },
        "sysId": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
        "deploymentId": { "type": "string", "minLength": 1, "maxLength": 255 },
        "approval": { "$ref": "#/definitions/valueDisplay" },
        "state": { "$ref": "#/definitions/valueDisplay" },
        "risk": { "$ref": "#/definitions/valueDisplay" },
        "assignmentGroup": { "$ref": "#/definitions/valueDisplay" },
        "window": {
          "type": "object",
          "additionalProperties": false,
          "required": ["startsAt", "endsAt"],
          "properties": {
            "startsAt": { "type": ["string", "null"], "format": "date-time" },
            "endsAt": { "type": ["string", "null"], "format": "date-time" }
          }
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["forwardNetworkId", "serviceEntityIds"],
      "properties": {
        "forwardNetworkId": { "type": "string", "minLength": 1, "maxLength": 255 },
        "serviceEntityIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 255 }
        }
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reasons", "eligibleStateValues", "approvedValues"],
      "properties": {
        "status": { "enum": ["eligible", "blocked"] },
        "reasons": {
          "type": "array",
          "maxItems": 100,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "message"],
            "properties": {
              "code": { "type": "string", "minLength": 1, "maxLength": 128 },
              "message": { "type": "string", "minLength": 1, "maxLength": 1000 }
            }
          }
        },
        "eligibleStateValues": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 128 }
        },
        "approvedValues": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 128 }
        }
      }
    },
    "nextStages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "enum": [
          "dynatrace-baseline",
          "forward-before-evidence",
          "customer-deployment",
          "dynatrace-post-change-health",
          "forward-after-evidence",
          "forward-reconciliation-dry-run",
          "combined-change-gate",
          "servicenow-evidence-feedback"
        ]
      }
    }
  },
  "definitions": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "valueDisplay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "display"],
      "properties": {
        "value": { "type": "string" },
        "display": { "type": "string" }
      }
    }
  }
}
