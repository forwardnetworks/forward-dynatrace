{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/forwardnetworks/forward-dynatrace/schemas/servicenow-scope-resolution.schema.json",
  "title": "Resolved ServiceNow change scope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "mappingId",
    "mappingSha256",
    "environmentId",
    "serviceNowInstanceAlias",
    "dynatraceEnvironmentAlias",
    "resolvedAt",
    "sourceRecords",
    "serviceEntityIds",
    "forwardNetworkId",
    "forwardEndpoints",
    "owner",
    "validity"
  ],
  "properties": {
    "schemaVersion": { "const": "forward-dynatrace-servicenow-scope-resolution/v1" },
    "mappingId": { "$ref": "#/definitions/identifier" },
    "mappingSha256": { "$ref": "#/definitions/sha256" },
    "environmentId": { "$ref": "#/definitions/identifier" },
    "serviceNowInstanceAlias": { "$ref": "#/definitions/identifier" },
    "dynatraceEnvironmentAlias": { "$ref": "#/definitions/identifier" },
    "resolvedAt": { "type": "string", "format": "date-time" },
    "sourceRecords": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": { "$ref": "#/definitions/sourceRecord" }
    },
    "serviceEntityIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 255 }
    },
    "forwardNetworkId": { "type": "string", "minLength": 1, "maxLength": 255 },
    "forwardEndpoints": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": { "$ref": "#/definitions/forwardEndpoint" }
    },
    "owner": { "$ref": "#/definitions/owner" },
    "validity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mappingObservedAt", "mappingExpiresAt", "minimumConfidence", "lowestConfidence"],
      "properties": {
        "mappingObservedAt": { "type": "string", "format": "date-time" },
        "mappingExpiresAt": { "type": "string", "format": "date-time" },
        "minimumConfidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "lowestConfidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  },
  "definitions": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["team", "contact"],
      "properties": {
        "team": { "type": "string", "minLength": 1, "maxLength": 128 },
        "contact": { "type": "string", "minLength": 1, "maxLength": 255 }
      }
    },
    "sourceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["table", "sysId"],
      "properties": {
        "table": { "type": "string", "pattern": "^[a-z][a-z0-9_]{0,79}$" },
        "sysId": { "type": "string", "pattern": "^[0-9a-f]{32}$" }
      }
    },
    "forwardEndpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["serviceEntityId", "locationType", "value"],
      "properties": {
        "serviceEntityId": { "type": "string", "minLength": 1, "maxLength": 255 },
        "locationType": { "enum": ["HostFilter", "SubnetLocationFilter", "DeviceFilter"] },
        "value": { "type": "string", "minLength": 1, "maxLength": 255 }
      }
    }
  }
}
