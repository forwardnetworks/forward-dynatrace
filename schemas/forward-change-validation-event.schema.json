{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/forwardnetworks/forward-dynatrace/schemas/forward-change-validation-event.schema.json",
  "title": "Forward for Dynatrace change-validation event",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "timestamp", "eventType", "severity", "title", "properties"],
  "properties": {
    "schemaVersion": { "const": "forward-dynatrace-change-validation-event/v1" },
    "timestamp": { "type": "string", "format": "date-time" },
    "eventType": { "const": "forward.dynatrace.change.validation" },
    "severity": { "enum": ["INFO", "WARN", "ERROR"] },
    "title": { "type": "string", "minLength": 1 },
    "properties": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "forward.dynatrace.gate_run_id",
        "forward.dynatrace.change_id",
        "forward.dynatrace.deployment_id",
        "forward.dynatrace.gate_decision",
        "forward.dynatrace.gate_reason_codes",
        "forward.dynatrace.gate_sha256",
        "forward.dynatrace.before_snapshot_id",
        "forward.dynatrace.after_snapshot_id",
        "forward.dynatrace.before_reachable",
        "forward.dynatrace.before_blocked",
        "forward.dynatrace.after_reachable",
        "forward.dynatrace.after_blocked"
      ],
      "properties": {
        "forward.dynatrace.gate_run_id": { "type": "string", "minLength": 1 },
        "forward.dynatrace.change_id": { "type": "string", "minLength": 1 },
        "forward.dynatrace.deployment_id": { "type": "string", "minLength": 1 },
        "forward.dynatrace.gate_decision": { "enum": ["pass", "warn", "fail"] },
        "forward.dynatrace.gate_reason_codes": { "type": "string", "minLength": 1 },
        "forward.dynatrace.gate_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "forward.dynatrace.network_id": { "type": "string", "minLength": 1 },
        "forward.dynatrace.before_snapshot_id": { "type": "string", "minLength": 1 },
        "forward.dynatrace.after_snapshot_id": { "type": "string", "minLength": 1 },
        "forward.dynatrace.before_reachable": { "type": "integer", "minimum": 0 },
        "forward.dynatrace.before_blocked": { "type": "integer", "minimum": 0 },
        "forward.dynatrace.after_reachable": { "type": "integer", "minimum": 0 },
        "forward.dynatrace.after_blocked": { "type": "integer", "minimum": 0 },
        "forward.dynatrace.after_ambiguous": { "type": "integer", "minimum": 0 },
        "forward.dynatrace.after_unmapped": { "type": "integer", "minimum": 0 },
        "forward.dynatrace.after_failed": { "type": "integer", "minimum": 0 },
        "forward.dynatrace.reconciliation_run_id": { "type": "string" },
        "forward.dynatrace.reconciliation_state": { "type": "string" },
        "forward.dynatrace.reconciliation_changed": { "type": "integer", "minimum": 0 },
        "forward.dynatrace.reconciliation_stale": { "type": "integer", "minimum": 0 },
        "forward.dynatrace.deployment_state": { "type": "string" },
        "forward.dynatrace.service_health": { "type": "string" },
        "forward.dynatrace.open_problem_count": { "type": "integer", "minimum": 0 },
        "forward.dynatrace.evidence_source": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
        "forward.dynatrace.synthetic": { "type": "boolean" },
        "forward.dynatrace.scope_mapping_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
        "forward.dynatrace.scope_mapping_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "forward.dynatrace.scope_environment_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
        "forward.dynatrace.scope_source_record_count": { "type": "integer", "minimum": 1, "maximum": 100 },
        "forward.dynatrace.correlation_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,254}$" },
        "forward.dynatrace.correlation_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "timeframe.from": { "type": "string", "format": "date-time" },
        "timeframe.to": { "type": "string", "format": "date-time" },
        "execution_context": { "$ref": "forward-guardian-execution-context.schema.json" }
      },
      "dependencies": {
        "forward.dynatrace.evidence_source": ["forward.dynatrace.synthetic"],
        "forward.dynatrace.synthetic": ["forward.dynatrace.evidence_source"],
        "forward.dynatrace.scope_mapping_id": [
          "forward.dynatrace.scope_mapping_sha256",
          "forward.dynatrace.scope_environment_id",
          "forward.dynatrace.scope_source_record_count"
        ],
        "forward.dynatrace.scope_mapping_sha256": ["forward.dynatrace.scope_mapping_id"],
        "forward.dynatrace.scope_environment_id": ["forward.dynatrace.scope_mapping_id"],
        "forward.dynatrace.scope_source_record_count": ["forward.dynatrace.scope_mapping_id"],
        "forward.dynatrace.correlation_id": [
          "forward.dynatrace.correlation_sha256",
          "timeframe.from",
          "timeframe.to",
          "execution_context"
        ],
        "forward.dynatrace.correlation_sha256": ["forward.dynatrace.correlation_id"],
        "timeframe.from": ["forward.dynatrace.correlation_id"],
        "timeframe.to": ["forward.dynatrace.correlation_id"],
        "execution_context": ["forward.dynatrace.correlation_id"]
      }
    }
  }
}
