{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/forwardnetworks/forward-dynatrace/schemas/connector-config.schema.json",
  "title": "Forward Dynatrace connector config",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion"],
  "properties": {
    "schemaVersion": { "const": "forward-dynatrace-connector/v1" },
    "apply": { "type": "boolean" },
    "applyUpdates": { "type": "boolean" },
    "approvalFile": { "$ref": "#/definitions/nonEmptyString" },
    "batchSize": { "type": "integer", "minimum": 1 },
    "changeWindowId": { "$ref": "#/definitions/nonEmptyString" },
    "checks": { "$ref": "#/definitions/nonEmptyString" },
    "checksUrl": { "$ref": "#/definitions/httpsUrl" },
    "deactivateStale": { "type": "boolean" },
    "failOnDrift": { "type": "boolean" },
    "forwardBaseUrl": { "$ref": "#/definitions/httpsUrl" },
    "forwardNetworkId": { "$ref": "#/definitions/nonEmptyString" },
    "manifest": { "$ref": "#/definitions/nonEmptyString" },
    "manifestUrl": { "$ref": "#/definitions/httpsUrl" },
    "maxDeactivations": { "type": "integer", "minimum": 0 },
    "maxPackageAgeMinutes": { "type": "integer", "minimum": 1 },
    "maxRetries": { "type": "integer", "minimum": 0 },
    "maxUpdates": { "type": "integer", "minimum": 0 },
    "metricsPath": { "$ref": "#/definitions/nonEmptyString" },
    "nqeChecks": { "$ref": "#/definitions/nonEmptyString" },
    "nqeChecksUrl": { "$ref": "#/definitions/httpsUrl" },
    "nqeDiffRequests": { "$ref": "#/definitions/nonEmptyString" },
    "nqeDiffRequestsUrl": { "$ref": "#/definitions/httpsUrl" },
    "nqeQueryIdAllowlist": { "$ref": "#/definitions/nonEmptyString" },
    "packageUrl": { "$ref": "#/definitions/httpsUrl" },
    "publicKey": { "$ref": "#/definitions/nonEmptyString" },
    "publicKeyUrl": { "$ref": "#/definitions/httpsUrl" },
    "requireSignature": { "type": "boolean" },
    "reportPath": { "$ref": "#/definitions/nonEmptyString" },
    "signature": { "$ref": "#/definitions/nonEmptyString" },
    "signatureUrl": { "$ref": "#/definitions/httpsUrl" },
    "statusArtifactPath": { "$ref": "#/definitions/nonEmptyString" },
    "validateOnly": { "type": "boolean" }
  },
  "definitions": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "httpsUrl": { "type": "string", "pattern": "^https://[^\\s]+$" }
  }
}
