// Latest lifecycle Guardian results correlated through the propagated execution_context.
// Filter by dt.srg.id or guardian tags in tenant-owned copies when more than one Guardian is deployed.

fetch events, from: now() - 30d
| filter event.kind == "SDLC_EVENT"
| filter event.provider == "dynatrace.site.reliability.guardian"
| filter event.type == "validation"
| filter event.status == "finished"
| fields
    timestamp,
    task.id,
    dt.srg.id,
    dt.srg.tags,
    validation.result,
    execution_context
| sort timestamp desc
| limit 100
