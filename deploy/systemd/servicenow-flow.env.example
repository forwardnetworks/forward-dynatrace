SERVICENOW_FLOW_USERNAME=<dedicated-flow-user>
SERVICENOW_FLOW_PASSWORD=<random-runtime-secret>
SERVICENOW_FLOW_HOST=127.0.0.1
SERVICENOW_FLOW_PORT=8080
SERVICENOW_FLOW_RUN_DIR=/var/lib/forward-dynatrace/servicenow-flow
SERVICENOW_FLOW_STALE_RUN_MS=1800000
SERVICENOW_FLOW_MAX_ACTIVE_RUNS=4
SERVICENOW_FLOW_EVIDENCE_SOURCE=live-customer-dependencies
SERVICENOW_FLOW_SYNTHETIC=0
SERVICENOW_FLOW_PUBLISH_SERVICENOW=0
SERVICENOW_FLOW_VERIFY_RETRY=0
SERVICENOW_FLOW_PUBLISH_DYNATRACE=0

SERVICENOW_BASE_URL=https://your-instance.service-now.com
SERVICENOW_USER=<read-only-integration-user>
SERVICENOW_PASSWORD=<runtime-secret>
SERVICENOW_FEEDBACK_USER=<assurance-writer-user>
SERVICENOW_FEEDBACK_PASSWORD=<runtime-secret>

FORWARD_BASE_URL=https://forward.example.com
FORWARD_USER=<user>
FORWARD_PASSWORD=<password-or-token>
FORWARD_READONLY_AUTHORIZATION=<runtime-secret>

# Configure these only when the worker should collect dependency evidence itself.
DYNATRACE_DEPENDENCY_QUERY_FILE=/etc/forward-dynatrace/customer-dependencies.dql
DYNATRACE_ENVIRONMENT_URL=https://your-environment-id.apps.dynatrace.com/
DYNATRACE_TOKEN_FILE=/etc/forward-dynatrace/platform-token
