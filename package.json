{
  "name": "forward-dynatrace",
  "version": "1.0.5",
  "description": "Forward Field Integration reference for exporting intent-check packages from Dynatrace service dependency evidence",
  "scripts": {
    "build": "dt-app build",
    "start": "dt-app dev",
    "create:function": "dt-app function create",
    "create:action": "dt-app action create",
    "uninstall": "dt-app uninstall",
    "deploy": "dt-app deploy",
    "update": "dt-app update",
    "info": "dt-app info",
    "help": "dt-app help",
    "repo:validate": "node scripts/validate-repo.mjs",
    "workflow:smoke": "node scripts/workflow-smoke.mjs",
    "runtime:validate": "node scripts/validate-runtime-manifests.mjs",
    "dynatrace:workflow:validate": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/validate-dynatrace-workflow-examples.mjs",
    "dynatrace:query": "node scripts/query-dynatrace-dependencies.mjs",
    "dynatrace:copy-demo": "node scripts/copy-dynatrace-demo-data.mjs",
    "dynatrace:normalize": "node scripts/normalize-dynatrace-dependencies.mjs",
    "dynatrace:normalize:test": "node --test scripts/normalize-dynatrace-dependencies.test.mjs",
    "dynatrace:bundle": "dt-app deploy --dry-run --no-open --non-interactive",
    "dynatrace:seed:demo": "node scripts/seed-dynatrace-demo-data.mjs",
    "demo:rehearsal": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/demo-rehearsal.mjs",
    "forward:nqe-artifacts:test": "node --test scripts/forward-nqe-artifacts.test.mjs",
    "forward:nqe-preview:test": "node --test --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/forward-nqe-preview.test.mjs",
    "forward:nqe-live-smoke": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/forward-nqe-live-smoke.mjs",
    "forward:nqe-live-smoke:test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/forward-nqe-live-smoke.mjs --forward-base-url https://forward.example.com --forward-network-id network-1 --output /tmp/forward-nqe-live-smoke-plan.json",
    "forward:package": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/build-forward-package.mjs",
    "forward:package:test": "node --test scripts/forward-package.test.mjs",
    "forward:import": "node scripts/forward-import-package.mjs",
    "forward:import:test": "node --test scripts/forward-import-package.test.mjs",
    "forward:status:test": "node --test --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/forward-status.test.mjs",
    "forward:status:publish": "node scripts/publish-forward-status.mjs",
    "forward:sign": "node scripts/sign-forward-package.mjs",
    "release:package": "node scripts/package-release-artifacts.mjs",
    "release:package:smoke": "node scripts/package-release-artifacts.mjs",
    "release:checksums": "node scripts/write-release-checksums.mjs",
    "release:checksums:test": "node --test scripts/release-checksums.test.mjs",
    "forward:status:publish:test": "node --test scripts/publish-forward-status.test.mjs",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "sbom:check": "npm sbom --omit=dev --sbom-format=cyclonedx > /tmp/forward-dynatrace-sbom.cdx.json",
    "whitespace:check": "git diff --check",
    "test": "npm run forward:import:test && npm run release:checksums:test",
    "lint": "eslint .",
    "ci": "npm run repo:validate && npm run whitespace:check && npm run forward:import:test && npm run forward:nqe-artifacts:test && npm run forward:nqe-preview:test && npm run forward:nqe-live-smoke:test && npm run forward:package:test && npm run forward:status:test && npm run forward:status:publish:test && npm run dynatrace:normalize:test && npm run release:checksums:test && npm run workflow:smoke && npm run runtime:validate && npm run dynatrace:workflow:validate && npm run demo:rehearsal && npm run security:audit && npm run sbom:check && npm run lint && npm run build && npm run release:package:smoke"
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dynatrace-sdk/app-environment": "^1.1.4",
    "@dynatrace-sdk/client-query": "^1.26.0",
    "@dynatrace-sdk/error-handlers": "^1.3.1",
    "@dynatrace-sdk/navigation": "^2.2.0",
    "@dynatrace-sdk/react-hooks": "^1.14.1",
    "@dynatrace-sdk/user-preferences": "^1.1.4",
    "@dynatrace/strato-components": "^3.3.1",
    "@dynatrace/strato-components-preview": "^3.3.1",
    "@dynatrace/strato-design-tokens": "^1.3.1",
    "@dynatrace/strato-icons": "^2.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "6.8.9",
    "react-router-dom": "^6.22.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@microsoft/eslint-plugin-sdl": "^1.1.0",
    "@types/node": "^24.7.0",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.5",
    "dt-app": "1.11.2",
    "eslint": "^9.37.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-no-secrets": "^2.2.1",
    "eslint-plugin-no-unsanitized": "^4.1.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^6.1.1",
    "eslint-plugin-security": "^3.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1"
  }
}
